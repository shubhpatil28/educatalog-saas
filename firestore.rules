rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── CORE HELPER FUNCTIONS ────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Safely check if the calling user has a Firestore profile
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Get user data — only call this AFTER confirming userExists()
    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Null-safe role check: returns false if profile doesn't exist
    function hasRole(role) {
      return isSignedIn() && userExists() && getUser().role == role;
    }

    // Null-safe school isolation check: returns false if profile doesn't exist
    function isSameSchool(schoolId) {
      return isSignedIn() && userExists() && getUser().schoolId == schoolId;
    }

    // ─── SCHOOLS COLLECTION ──────────────────────────────────────────────
    match /schools/{schoolId} {
      // Any authenticated user can read schools.
      // Needed for:
      //   (a) Login: institution code validation after sign-in
      //   (b) Registration: unique code generation check
      allow read: if isSignedIn();

      // Only the principal of THIS school or superadmin can update it
      allow update: if isSignedIn() && (
        (hasRole('principal') && isSameSchool(schoolId)) ||
        hasRole('superadmin')
      );

      // Allow creation during registration (authenticated user, new doc)
      allow create: if isSignedIn();
    }

    // ─── USERS COLLECTION ────────────────────────────────────────────────
    match /users/{userId} {
      // Read: self, principal of same school, or superadmin
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        (hasRole('principal') && isSameSchool(resource.data.schoolId)) ||
        hasRole('superadmin')
      );

      // Create: only the user themselves (auto-create on register/login healing)
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Update: self (no role/schoolId escalation), principal of same school, or superadmin
      allow update: if isSignedIn() && (
        (request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'schoolId'])) ||
        (hasRole('principal') && isSameSchool(resource.data.schoolId) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'schoolId'])) ||
        hasRole('superadmin')
      );
    }

    // ─── STUDENTS COLLECTION ─────────────────────────────────────────────
    match /students/{studentId} {
      function canReadStudent() {
        let u = getUser();
        return (
          (u.role == 'principal' && u.schoolId == resource.data.schoolId) ||
          (u.role == 'teacher'
            && u.schoolId == resource.data.schoolId
            && u.get('class', '') == resource.data.class
            && u.get('division', '') == resource.data.division) ||
          u.role == 'superadmin'
        );
      }

      function canWriteStudent() {
        let u = getUser();
        let target = request.resource.data;
        return (
          (u.role == 'principal' && u.schoolId == target.schoolId) ||
          (u.role == 'teacher'
            && u.schoolId == target.schoolId
            && u.get('class', '') == target.class
            && u.get('division', '') == target.division) ||
          u.role == 'superadmin'
        );
      }

      allow read: if isSignedIn() && userExists() && canReadStudent();
      allow write: if isSignedIn() && userExists() && canWriteStudent();
    }

    // ─── ATTENDANCE COLLECTION ───────────────────────────────────────────
    match /attendance/{attendanceId} {
      function canAccessAttendance(data) {
        let u = getUser();
        return (
          (u.role == 'principal' && u.schoolId == data.schoolId) ||
          (u.role == 'teacher'
            && u.schoolId == data.schoolId
            && u.get('class', '') == data.class
            && u.get('division', '') == data.division) ||
          u.role == 'superadmin'
        );
      }

      allow read: if isSignedIn() && userExists() && canAccessAttendance(resource.data);
      allow write: if isSignedIn() && userExists() && canAccessAttendance(request.resource.data);
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── CORE HELPER FUNCTIONS ────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && userExists() && getUser().role == role;
    }

    function isSameSchool(schoolId) {
      return isSignedIn() && userExists() && getUser().schoolId == schoolId;
    }

    // ─── SCHOOLS COLLECTION ──────────────────────────────────────────────
    match /schools/{schoolId} {
      // Authenticated users can read/create schools (registration flow)
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() && (
        (hasRole('principal') && isSameSchool(schoolId)) || 
        hasRole('superadmin')
      );
    }

    // ─── USERS COLLECTION ────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        (hasRole('principal') && isSameSchool(resource.data.schoolId)) ||
        hasRole('superadmin')
      );
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'schoolId'])) ||
        (hasRole('principal') && isSameSchool(resource.data.schoolId)) ||
        hasRole('superadmin')
      );
    }

    // ─── STUDENTS COLLECTION ─────────────────────────────────────────────
    match /students/{studentId} {
      allow read: if isSignedIn() && (
        (hasRole('principal') && isSameSchool(resource.data.schoolId)) ||
        (hasRole('teacher') && isSameSchool(resource.data.schoolId) && 
         getUser().class == resource.data.class && 
         getUser().division == resource.data.division) ||
        hasRole('superadmin')
      );
      
      allow create: if isSignedIn() && (
        (hasRole('principal') && isSameSchool(request.resource.data.schoolId)) ||
        (hasRole('teacher') && isSameSchool(request.resource.data.schoolId) && 
         getUser().class == request.resource.data.class && 
         getUser().division == request.resource.data.division) ||
        hasRole('superadmin')
      );
      
      allow update, delete: if isSignedIn() && (
        (hasRole('principal') && isSameSchool(resource.data.schoolId)) ||
        (hasRole('teacher') && isSameSchool(resource.data.schoolId) && 
         getUser().class == resource.data.class && 
         getUser().division == resource.data.division) ||
        hasRole('superadmin')
      );
    }
 
    // ─── ATTENDANCE COLLECTION ───────────────────────────────────────────
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (
        (hasRole('principal') && isSameSchool(resource.data.schoolId)) ||
        (hasRole('teacher') && isSameSchool(resource.data.schoolId) && 
         getUser().class == resource.data.class && 
         getUser().division == resource.data.division) ||
        hasRole('superadmin')
      );
      
      allow create: if isSignedIn() && (
        (hasRole('principal') && isSameSchool(request.resource.data.schoolId)) ||
        (hasRole('teacher') && isSameSchool(request.resource.data.schoolId) && 
         getUser().class == request.resource.data.class && 
         getUser().division == request.resource.data.division) ||
        hasRole('superadmin')
      );
      
      allow update, delete: if isSignedIn() && (
        (hasRole('principal') && isSameSchool(resource.data.schoolId)) ||
        (hasRole('teacher') && isSameSchool(resource.data.schoolId) && 
         getUser().class == resource.data.class && 
         getUser().division == resource.data.division) ||
        hasRole('superadmin')
      );
    }

    // ─── DENY ALL OTHER ACCESS ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

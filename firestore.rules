rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── OPTIMIZED HELPER FUNCTIONS ──────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUser() {
      // Single source of truth for user metadata (Role, SchoolId, Class/Div)
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return getUser().role == role;
    }

    function isSameSchool(schoolId) {
      return getUser().schoolId == schoolId;
    }

    // ─── SCHOOLS COLLECTION ─────────────────────────────────────────────
    match /schools/{schoolId} {
      // Principals and Teachers need to read their institution data
      allow read: if isSignedIn() && (isSameSchool(schoolId) || hasRole('superadmin'));
      
      // Only Principal of that school or superadmin can modify settings
      allow update: if isSignedIn() && (
        (hasRole('principal') && isSameSchool(schoolId)) || 
        hasRole('superadmin')
      );
      
      // Allow creation during registration; role check not needed yet as doc doesn't exist
      allow create: if isSignedIn();
    }

    // ─── USERS COLLECTION ───────────────────────────────────────────────
    match /users/{userId} {
      // Profile access: Self-access or Principal/Superadmin oversight
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        (hasRole('principal') && isSameSchool(resource.data.schoolId)) ||
        hasRole('superadmin')
      );
      
      allow create: if isSignedIn() && request.auth.uid == userId;

      allow update: if isSignedIn() && (
        // Self-edit: Prevent role or schoolId escalation
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'schoolId'])) ||
        // Principal managing school staff (Teachers)
        (hasRole('principal') && isSameSchool(resource.data.schoolId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'schoolId'])) ||
        // Superadmin full control
        hasRole('superadmin')
      );
    }

    // ─── STUDENTS COLLECTION ────────────────────────────────────────────
    match /students/{studentId} {
      function canReadStudent() {
        let u = getUser();
        return (
          (u.role == 'principal' && u.schoolId == resource.data.schoolId) ||
          (u.role == 'teacher' && u.schoolId == resource.data.schoolId && u.class == resource.data.class && u.division == resource.data.division) ||
          u.role == 'superadmin'
        );
      }

      function canWriteStudent() {
        let u = getUser();
        // For 'create', check if incoming data matches user's jurisdiction
        let target = request.resource.data;
        return (
          (u.role == 'principal' && u.schoolId == target.schoolId) ||
          (u.role == 'teacher' && u.schoolId == target.schoolId && u.class == target.class && u.division == target.division) ||
          u.role == 'superadmin'
        );
      }

      allow read: if isSignedIn() && canReadStudent();
      allow write: if isSignedIn() && canWriteStudent();
    }

    // ─── ATTENDANCE COLLECTION ──────────────────────────────────────────
    match /attendance/{attendanceId} {
      function canAccessAttendance(data) {
        let u = getUser();
        return (
          (u.role == 'principal' && u.schoolId == data.schoolId) ||
          (u.role == 'teacher' && u.schoolId == data.schoolId && u.class == data.class && u.division == data.division) ||
          u.role == 'superadmin'
        );
      }

      allow read: if isSignedIn() && canAccessAttendance(resource.data);
      allow write: if isSignedIn() && canAccessAttendance(request.resource.data);
    }
  }
}
